{
  "name": "jason-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build && vite build --ssr src/entry-server.ts --outDir dist/server && node scripts/prerender.mjs",
    "preview": "vite preview",
    "bore": "bore local 5173 --to bore.pub",
    "lint:caps": "node scripts/lint-lang-caps.mjs",
    "lint:caps:fix": "node scripts/lint-lang-caps.mjs --fix"
  },
  "dependencies": {
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vue-tsc": "^3.2.5"
  }
}
